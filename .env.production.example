# App
DEBUG=false
JWT_SECRET_KEY=replace-with-a-long-random-secret
DATABASE_URL=postgresql://app_user:strong_password@db-host:5432/tontine_db
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
REGISTER_OTP_EXPIRE_MINUTES=5
REGISTER_OTP_MAX_ATTEMPTS=3
REGISTER_OTP_RESEND_COOLDOWN_SECONDS=30
REGISTER_OTP_VERIFIED_TTL_MINUTES=30

# URLs
BASE_URL=https://api.your-domain.com
FRONTEND_URL=https://app.your-domain.com
CORS_ALLOW_ORIGINS=https://app.your-domain.com

# Auto reminders
AUTO_REMINDER_ENABLED=true
AUTO_REMINDER_INTERVAL_SECONDS=3600
AUTO_REMINDER_LOOKAHEAD_HOURS=24

# Twilio (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Support email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SUPPORT_EMAIL_TO=

# Flutterwave (optional)
FLW_CLIENT_ID=
FLW_CLIENT_SECRET=
FLW_ENCRYPTION_KEY=
FLW_SECRET_HASH=

# Monetbil (optional)
MONETBIL_API_KEY=
MONETBIL_SERVICE_KEY=
MONETBIL_WEBHOOK_SECRET=
